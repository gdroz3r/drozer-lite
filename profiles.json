{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "description": "Deterministic protocol-type detection patterns. Each profile lists regex patterns; a match against the source contributes to the profile's score. Profiles whose score clears the threshold are loaded alongside the always-on universal profile. Profiles with empty patterns (icp, solana) are explicit-only — never auto-selected, only loaded via --profile.",
  "threshold": 3,
  "always_loaded": ["universal"],
  "explicit_only": ["icp", "solana"],
  "profiles": {
    "signature": {
      "patterns": [
        "\\bEIP712\\b",
        "\\bpermit\\s*\\(",
        "\\becrecover\\s*\\(",
        "isValidSignature",
        "\\bpermitWitnessTransferFrom\\b",
        "\\b_hashTypedDataV4\\b",
        "\\bDOMAIN_SEPARATOR\\b"
      ],
      "description": "Meta-transactions, permit flows, EIP-712 signature verification."
    },
    "vault": {
      "patterns": [
        "\\bERC4626\\b",
        "\\btotalAssets\\b",
        "\\bpreviewDeposit\\b",
        "\\bpreviewWithdraw\\b",
        "\\bconvertToShares\\b",
        "\\bconvertToAssets\\b",
        "\\bfunction\\s+deposit\\s*\\(",
        "\\bfunction\\s+withdraw\\s*\\("
      ],
      "description": "ERC-4626 / share-based vaults."
    },
    "lending": {
      "patterns": [
        "\\bborrow\\b",
        "\\bliquidate\\b",
        "\\bcollateral\\b",
        "\\bhealthFactor\\b",
        "\\bLTV\\b",
        "\\bdebtToken\\b",
        "\\binterestRate\\b"
      ],
      "description": "Lending markets, collateral valuation, liquidation."
    },
    "dex": {
      "patterns": [
        "\\bswap\\b",
        "\\baddLiquidity\\b",
        "\\bremoveLiquidity\\b",
        "\\bamountOutMin\\b",
        "IUniswapV[23]",
        "\\bISwapRouter\\b",
        "\\bsqrtPriceX96\\b"
      ],
      "description": "AMM / DEX integrations, swap routers, liquidity pools."
    },
    "cross-chain": {
      "patterns": [
        "\\blzReceive\\b",
        "\\bccipReceive\\b",
        "\\bsetPeer\\b",
        "\\bsetTrustedRemote\\b",
        "\\bwormhole\\b",
        "\\bIReceiver\\b",
        "\\bbridge\\b"
      ],
      "description": "Cross-chain message passing (LayerZero, CCIP, Wormhole, etc.)."
    },
    "governance": {
      "patterns": [
        "\\bpropose\\s*\\(",
        "\\bcastVote\\s*\\(",
        "\\bquorum\\b",
        "\\bdelegate\\s*\\(",
        "\\bGovernor\\b",
        "\\bTimelock\\b",
        "\\bvotingPower\\b"
      ],
      "description": "On-chain governance, voting, delegation, timelocks."
    },
    "reentrancy": {
      "patterns": [
        "\\bnonReentrant\\b",
        "\\bReentrancyGuard\\b",
        "\\.call\\s*\\{\\s*value",
        "\\bonERC721Received\\b",
        "\\bonERC1155Received\\b",
        "\\btokensReceived\\b",
        "\\bERC777\\b"
      ],
      "description": "External calls, callback hooks, reentrancy-prone surfaces (ERC777/721/1155 receivers, .call{value:})."
    },
    "oracle": {
      "patterns": [
        "AggregatorV[23]Interface",
        "\\blatestRoundData\\b",
        "\\blatestAnswer\\b",
        "\\bIChainlink",
        "\\bpriceFeed\\b",
        "\\bgetPrice\\b",
        "\\boracle\\b",
        "\\bIPyth\\b"
      ],
      "description": "Price oracles, Chainlink/Pyth feeds, on-chain price reads."
    },
    "math": {
      "patterns": [
        "\\bFixedPoint\\b",
        "\\bPRBMath\\b",
        "\\bmulDiv\\b",
        "\\bSafeMath\\b",
        "\\bWAD\\b",
        "\\bRAY\\b",
        "\\bUFixed\\d+\\b",
        "\\bSD\\d+x\\d+\\b",
        "\\bUD\\d+x\\d+\\b"
      ],
      "description": "Fixed-point math libraries, decimal scaling, custom precision arithmetic."
    },
    "gaming": {
      "patterns": [
        "\\bVRFConsumerBase\\b",
        "\\bVRFCoordinator\\b",
        "\\brandomness\\b",
        "\\braffle\\b",
        "\\blottery\\b",
        "\\brequestRandomWords\\b",
        "\\bfulfillRandomWords\\b"
      ],
      "description": "Lottery, raffle, VRF-driven randomness consumers."
    },
    "icp": {
      "patterns": [],
      "description": "Internet Computer canister (Rust). Explicit-only — never auto-detected. Pass --profile icp to load this checklist when auditing IC code outside drozer-lite's standard .sol scope."
    },
    "solana": {
      "patterns": [],
      "description": "Solana program (Anchor / native Rust). Explicit-only — never auto-detected. Pass --profile solana to load this checklist when auditing Solana code outside drozer-lite's standard .sol scope."
    }
  }
}
