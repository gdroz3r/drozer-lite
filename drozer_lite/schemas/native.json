{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "drozer-lite native output",
  "description": "drozer-lite's canonical finding schema. Output adapters translate this into other formats (markdown, sarif, forefy, etc.).",
  "type": "object",
  "required": ["scanner", "version", "findings"],
  "properties": {
    "scanner": { "const": "drozer-lite" },
    "version": { "type": "string" },
    "profiles_used": {
      "type": "array",
      "items": { "type": "string" }
    },
    "files_analyzed": {
      "type": "array",
      "items": { "type": "string" }
    },
    "findings": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "vulnerability_type",
          "affected_function",
          "affected_file",
          "severity",
          "explanation"
        ],
        "properties": {
          "vulnerability_type": {
            "type": "string",
            "description": "Canonical drozer-lite native tag (e.g. 'reentrancy', 'tx_origin_auth')."
          },
          "affected_function": { "type": "string" },
          "affected_file": { "type": "string" },
          "severity": {
            "enum": ["CRITICAL", "HIGH", "MEDIUM", "LOW", "INFO"]
          },
          "explanation": {
            "type": "string",
            "description": "One-sentence root cause referencing specific code."
          },
          "line_hint": {
            "type": ["integer", "null"],
            "minimum": 1
          },
          "confidence": {
            "enum": ["HIGH", "MEDIUM", "LOW"],
            "default": "MEDIUM"
          },
          "source_profile": {
            "type": "string",
            "description": "Which profile checklist caught the finding."
          },
          "swc_id": { "type": ["string", "null"] },
          "cwe_id": { "type": ["string", "null"] },
          "original_type": {
            "type": ["string", "null"],
            "description": "The LLM's raw vulnerability_type before vocabulary canonicalization."
          }
        }
      }
    },
    "stats": {
      "type": "object",
      "properties": {
        "llm_calls": { "type": "integer" },
        "wall_time_sec": { "type": "number" },
        "retries": { "type": "integer" },
        "dedup_clusters_merged": { "type": "integer" }
      }
    },
    "warnings": {
      "type": "array",
      "items": { "type": "string" }
    }
  }
}
